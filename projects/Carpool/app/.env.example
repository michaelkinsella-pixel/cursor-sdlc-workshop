# Copy this file to .env.local and fill in the values you actually want.
# .env.local is git-ignored.

# PostHog product analytics. Without these, src/data/analytics.js runs in
# no-op mode (every event becomes a console.debug, no network calls).
# Sign up at https://posthog.com — Hobby plan is free up to 1M events / mo.
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase backend. Use the public Project URL and public anon key from:
# Supabase dashboard -> Project Settings -> API
# Never put the service_role key in a browser app.
# VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...
